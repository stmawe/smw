# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.localhost

# Database
DB_ENGINE=django_tenants.postgresql_backend
DB_NAME=smw
DB_USER=postgres
DB_PASSWORD=admin
DB_HOST=localhost
DB_PORT=5432

# Database SSL (optional, for cloud databases)
DB_SSLMODE=disable
DB_SSLROOTCERT=

# Tenant Configuration
PUBLIC_SCHEMA_DOMAIN=localhost
PUBLIC_SCHEMA_NAME=public
BASE_DOMAIN=localhost
TENANT_SUBFOLDER_PREFIX=

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=studentsmarketingweb@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
DEFAULT_FROM_EMAIL=studentsmarketingweb@gmail.com
EMAIL_USE_TLS=True

# M-Pesa Configuration (Phase 10)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback/
MPESA_SANDBOX=True

# Storage Configuration
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Redis Configuration (for WebSockets/Caching)
REDIS_URL=redis://localhost:6379/0
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache

# Security
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# Logging
LOG_LEVEL=INFO

# AI Features (Phase 12)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Admin Panel Theme (Phase 11)
ADMIN_THEME=django-unfold

# Cloudflare API (for DNS in production)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# Server IP — used to create Cloudflare A records for shop subdomains
SERVER_IP=
